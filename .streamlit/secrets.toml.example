# Copy ONE provider shape into the Streamlit Community Cloud app's Secrets panel.
# Never commit real credentials.

# Option A: Metered, OpenRelay, or a private coturn server.
[turn]
urls = [
  "turn:YOUR_TURN_HOST:443?transport=udp",
  "turn:YOUR_TURN_HOST:443?transport=tcp",
  "turns:YOUR_TURN_HOST:443?transport=tcp",
]
username = "YOUR_EPHEMERAL_USERNAME"
credential = "YOUR_EPHEMERAL_CREDENTIAL"

# Option B: Twilio Network Traversal. SafePath exchanges these server-side for
# one-hour ephemeral STUN/TURN credentials and caches them for 55 minutes.
# [twilio]
# account_sid = "ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# auth_token = "YOUR_TWILIO_AUTH_TOKEN"
